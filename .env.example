# Copy to .env.local and fill in real values for any non-dev deployment.
# The committed .env holds safe local-dev defaults only.

# Prisma datasource. SQLite for dev; a Postgres URL for production.
DATABASE_URL="file:./dev.db"

# NextAuth. In production this MUST be a strong, unique secret — the app refuses
# to boot with the dev placeholder when NODE_ENV=production.
# Generate one with:  openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
